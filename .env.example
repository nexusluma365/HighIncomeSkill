# Stripe
# Optional. The test publishable key is built into the app config; set this only to override it.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=sk_live_or_test_key_here

# Cloudflare R2 digital product delivery
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# These match the env names already shown in Netlify.
R2_BUCKET=digitalskills
R2_BUCKET2=digitalskills
R2_BUCKET3=digitalskills
R2_FILE_KEY_BUNDLE=digitalskillsproudct/Complete Digital Skill Bundle.zip
R2_FILE_KEY_AI_ASSISTANT=digitalskillsproudct/Digital Skills Bundle + Automation .zip
R2_FILE_KEY_WEBSITE_VOICE=digitalskillsproudct/Digital Skills Bundle + Website Template SEO.zip

# Optional product-specific overrides. Use these only if you prefer cleaner names.
PRODUCT_WORK_FROM_ANYWHERE_BUCKET=
PRODUCT_WORK_FROM_ANYWHERE_FILE_KEY=
PRODUCT_WORK_FROM_ANYWHERE_FILE_NAME=Complete Digital Skill Bundle.zip
PRODUCT_AI_AUTOMATION_BUCKET=
PRODUCT_AI_AUTOMATION_FILE_KEY=
PRODUCT_AI_AUTOMATION_FILE_NAME=Digital Skills Bundle + Automation .zip
PRODUCT_WEBSITE_SEO_BUCKET=
PRODUCT_WEBSITE_SEO_FILE_KEY=
PRODUCT_WEBSITE_SEO_FILE_NAME=Digital Skills Bundle + Website Template SEO.zip

# Optional. If omitted, STRIPE_SECRET_KEY signs the temporary on-site download tokens.
DOWNLOAD_TOKEN_SECRET=make_this_a_long_random_string

# Google Sheets event logging
# Recommended option: service account direct Sheets API access.
GOOGLE_SHEETS_ID=your_google_sheet_id
GOOGLE_SHEETS_TAB=Q1
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional. The current Apps Script URL is built in; set this only to override it.
GOOGLE_APPS_SCRIPT_URL=
